{
  "manifest_version": 3,
  "name": "SnipLaunch",
  "version": "1.2",
  "description": "Open a random bookmark from chosen folders, limited to selected domains.",
  "permissions": ["storage", "bookmarks", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
